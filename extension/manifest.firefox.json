{
  "manifest_version": 3,
  "name": "TranslateSafe Assistant",
  "version": "2.3",
  "description": "Auto-translate selected text and sync to flashcards.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "translatesafe@translatesafe.app",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "http://127.0.0.1:3000/*", "https://*.run.app/*"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["browser-polyfill.js", "text_selection.js"],
      "css": ["selection.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TranslateSafe"
  },
  "commands": {
    "toggle_mode": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Toggle Instant Translation Mode"
    }
  }
}
